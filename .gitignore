# Obsidian per-user state (workspace + cache + plugin data)
.obsidian/workspace.json
.obsidian/workspace-*.json
.obsidian/plugins/*/data.json
.obsidian/cache
.smart-connections/
.obsidian-git-data
.trash/

# System
.DS_Store
**/.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# Local secrets
.env
.env.local
*.local.md

# Personal files dropped into vault root by Obsidian (don't commit these)
/WIKI*.md
/PROMPT.md
/Welcome.md
*.tmp.*
Obsidian vault*
Untitled.canvas
Untitled *.canvas
Untitled.base

# Bases dashboards: ignore by default
*.base

# Video and large media files
*.mkv
*.mp4
*.mov
*.avi

# Transcripts (copyright — do not commit)
*Trascipt*.txt
*Transcript*.txt

# User-specific attachments
_attachments/

# graphify test artifacts (don't ship venvs or test outputs in the plugin repo)
.venv-graphify/
/graphify-out/

# Per-developer IDE / editor state
.idea/
.vscode/

# Per-developer Claude Code session settings (allowlists, worktrees)
.claude/settings.local.json
.claude/worktrees/


# Test-only Python pin (the graphify-ingest skill installs its own)
.python-version

# Cursor reference copy (temporary; remove after cleanup phase wraps)
_cursor/
